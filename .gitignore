# ═══════════════════════════════════════════════════════════
# Rust / Cargo
# ═══════════════════════════════════════════════════════════
/target/
**/*.rs.bk
# NOTE: Cargo.lock is NOT ignored — it must be committed for
# binary crates to ensure reproducible builds across CI/CD.

# ═══════════════════════════════════════════════════════════
# Build Artifacts
# ═══════════════════════════════════════════════════════════
*.pdb
*.exe
*.dll
*.dylib
*.so
*.d
*.o
*.obj
*.lib
*.rlib

# ═══════════════════════════════════════════════════════════
# IDE / Editor
# ═══════════════════════════════════════════════════════════
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~

# ═══════════════════════════════════════════════════════════
# OS Generated
# ═══════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ═══════════════════════════════════════════════════════════
# Environment / Secrets
# ═══════════════════════════════════════════════════════════
.env
.env.*
*.key
*.pem
*.pfx
*.crt
*.p12

# ═══════════════════════════════════════════════════════════
# Overthrone — Output & Loot
# ═══════════════════════════════════════════════════════════
/output/
/loot/
/reports/
*.pdf
*.html.report
*.json.report

# ═══════════════════════════════════════════════════════════
# Overthrone — Credential & Dump Files
# ═══════════════════════════════════════════════════════════
*.ntds
*.dit
*.sam
*.system
*.security
*.dmp
*secretsdump*
*hashdump*
*.kirbi
*.ccache
cracked_credentials.txt
*cracked*.txt

# ═══════════════════════════════════════════════════════════
# Overthrone — Payloads & Staging
# ═══════════════════════════════════════════════════════════
/payloads/
/staging/
*.bin
*.shellcode

# ═══════════════════════════════════════════════════════════
# Logs & Debug
# ═══════════════════════════════════════════════════════════
*.log
*.trace
/logs/

# ═══════════════════════════════════════════════════════════
